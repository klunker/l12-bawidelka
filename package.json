{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vp build",
        "build:simple": "./scripts/build-simple.sh",
        "build:ssr": "vp build && vp build --ssr",
        "build:git": "./scripts/build-with-git.sh",
        "act:lint": "./scripts/run-act.sh lint",
        "act:tests": "./scripts/run-act.sh tests",
        "act:all": "./scripts/run-act.sh all",
        "act:list": "./scripts/run-act.sh list",
        "env:switch": "./scripts/switch-env.sh",
        "env:dev": "./scripts/switch-env.sh development",
        "env:prod": "./scripts/switch-env.sh production",
        "env:local": "./scripts/switch-env.sh local",
        "help": "./scripts/scripts-help.sh",
        "help:simple": "./scripts/scripts-help-simple.sh",
        "help:build": "./scripts/scripts-help.sh build",
        "help:ci": "./scripts/scripts-help.sh ci",
        "help:dev": "./scripts/scripts-help.sh dev",
        "dev": "vp dev",
        "format": "vp fmt resources/",
        "format:check": "vp fmt --check resources/",
        "lint": "vp lint . --fix",
        "lint:check": "vp lint .",
        "types:check": "tsc --noEmit",
        "prepare": "vp config"
    },
    "dependencies": {
